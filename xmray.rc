#!/sbin/openrc-run

description="XMRay Service"

extra_started_commands="reload"

command="/usr/local/XMRay/XMRay"
command_args="run --config /etc/XMRay/config.yml"

pidfile="/run/$RC_SVCNAME.pid"
required_files="/etc/XMRay/config.yml"

depend() {
	want net
}

reload() {
	start-stop-daemon --signal HUP --exec "$command" --pidfile "$pidfile"
}
